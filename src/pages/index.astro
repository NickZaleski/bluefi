---
import '../styles/global.css';
import CelestialBackground from '../components/CelestialBackground.astro';
import Player from '../components/Player.astro';
import Credits from '../components/Credits.astro';

const title = 'Ola Celeste — beside the point × Bluefi';
const description =
  'Ola Celeste — a LoFi collaboration by beside the point (Poland) and BlueFI (Puerto Rico). Press play and drift.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / social -->
    <meta property="og:type" content="music.song" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="theme-color" content="#0b0821" />

    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ccircle cx='50' cy='50' r='48' fill='%232e1e6a'/%3E%3Ccircle cx='38' cy='40' r='4' fill='%23a7e8e0'/%3E%3Ccircle cx='64' cy='58' r='3' fill='%23f198ad'/%3E%3Ccircle cx='56' cy='30' r='2.5' fill='%23fff'/%3E%3C/svg%3E" />
  </head>

  <body>
    <CelestialBackground />

    <main class="stage">
      <Player />
      <Credits />
    </main>

    <style>
      .stage {
        min-height: 100svh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: clamp(1.5rem, 5vw, 3rem);
      }
    </style>
  </body>
</html>
