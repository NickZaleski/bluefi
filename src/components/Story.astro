---
// Backstory section — appears as you scroll below the player hero.
// Two artists, two continents, one track made over Discord; and an open call
// to labels. Reveals on scroll (IntersectionObserver), respects reduced motion.
---

<section class="story" id="story" aria-label="The story behind Ola Celeste">
  <div class="story__panel" data-reveal>
    <span class="story__eyebrow">The Story</span>

    <p class="story__lead">
      <strong>Liam</strong> (Bluefi) and <strong>Nick</strong> (beside the point)
      have never met. They live on different continents.
    </p>

    <p>
      But they made this track together — remotely, talking on
      <span class="story__hl">Discord</span>. For the sake of the art.
    </p>

    <p class="story__tag story__call">Connect, create, and make friends. Live.</p>

    <div class="story__contact">
      <a class="story__email" href="mailto:besidethepointmusic@gmail.com">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path
            d="M4 5h16a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1zm0 2v.4l8 5 8-5V7H4zm16 2.6-8 5-8-5V17h16V9.6z"
            fill="currentColor"
          />
        </svg>
        besidethepointmusic@gmail.com
      </a>

      <div class="story__links">
        <a
          class="story__link"
          href="https://linktr.ee/besidethepoint"
          target="_blank"
          rel="noopener noreferrer"
        >
          beside the point
        </a>
        <a
          class="story__link"
          href="https://linktr.ee/bluefimusic"
          target="_blank"
          rel="noopener noreferrer"
        >
          Bluefi
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  // Fade + rise reveal when the panel scrolls into view.
  const targets = document.querySelectorAll('[data-reveal]');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reduce || !('IntersectionObserver' in window)) {
    targets.forEach((t) => t.classList.add('is-visible'));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.25 }
    );
    targets.forEach((t) => io.observe(t));
  }
</script>

<style>
  .story {
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(3rem, 10vh, 7rem) clamp(1.5rem, 5vw, 3rem);
  }

  .story__panel {
    width: min(620px, 92vw);
    padding: clamp(2rem, 6vw, 3.4rem);
    border-radius: 26px;
    text-align: center;
    background: rgba(20, 16, 46, 0.42);
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow:
      0 24px 70px -20px rgba(0, 0, 0, 0.6),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(22px) saturate(1.2);
    -webkit-backdrop-filter: blur(22px) saturate(1.2);

    /* reveal-on-scroll initial state */
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.9s ease, transform 0.9s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .story__panel.is-visible {
    opacity: 1;
    transform: none;
  }

  .story__eyebrow {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(226, 220, 255, 0.6);
    margin-bottom: 1.6rem;
  }

  .story p {
    color: rgba(236, 231, 255, 0.9);
    font-size: clamp(1.05rem, 2.6vw, 1.35rem);
    line-height: 1.65;
    margin: 0 auto 1.15rem;
    max-width: 44ch;
  }
  .story p:last-child {
    margin-bottom: 0;
  }

  .story__lead {
    font-size: clamp(1.2rem, 3vw, 1.6rem) !important;
    color: #f4f0ff !important;
    line-height: 1.5 !important;
  }
  .story strong {
    font-weight: 600;
    color: #fff;
  }

  .story__hl {
    color: #a7e8e0;
    font-weight: 600;
  }

  .story__call {
    margin-top: 1.8rem !important;
    padding-top: 1.6rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .story__call strong {
    background: linear-gradient(120deg, #fff 0%, #dcd0ff 45%, #a7e8e0 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .story__tag {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 3vw, 1.5rem) !important;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: #fff !important;
    margin-top: 0.4rem !important;
  }

  .story__contact {
    margin-top: 2.2rem;
    padding-top: 1.8rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
  }

  .story__email {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1.4rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: clamp(0.9rem, 2.4vw, 1.05rem);
    color: #16112e;
    background: radial-gradient(circle at 35% 30%, #fef0f5, #e6c7ec 55%, #b79ce0 100%);
    box-shadow: 0 8px 26px -8px rgba(183, 156, 224, 0.7);
    transition: transform 0.2s ease, box-shadow 0.3s ease;
    word-break: break-all;
  }
  .story__email:hover,
  .story__email:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 12px 34px -8px rgba(183, 156, 224, 0.95);
    outline: none;
  }
  .story__email svg {
    flex: 0 0 auto;
  }

  .story__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem 0.9rem;
  }
  .story__link {
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    text-decoration: none;
    font-size: 0.95rem;
    color: #f2ecff;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.05);
    transition: transform 0.25s ease, box-shadow 0.35s ease,
      border-color 0.35s ease, background 0.35s ease;
  }
  .story__link:hover,
  .story__link:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(199, 169, 240, 0.6);
    background: rgba(199, 169, 240, 0.12);
    box-shadow: 0 8px 30px -10px rgba(147, 96, 205, 0.7);
    outline: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .story__panel {
      transition: none;
    }
  }
</style>
