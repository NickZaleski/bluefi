---
// Custom-styled audio player for the single track "Ola Celeste".
// The native <audio> element is the engine; all visible controls are custom.
const trackSrc = '/audio/Ola%20Celeste.mp3';
const trackTitle = 'Ola Celeste';
---

<section class="player" data-player aria-label="Audio player">
  <audio data-audio src={trackSrc} preload="metadata" loop></audio>

  <div class="player__meta">
    <span class="player__eyebrow">Now playing</span>
    <h1 class="player__title">{trackTitle}</h1>
  </div>

  <div class="player__controls">
    <button
      type="button"
      class="player__play"
      data-play
      aria-label="Play"
      aria-pressed="false"
    >
      <svg class="icon-play" viewBox="0 0 24 24" width="28" height="28" aria-hidden="true">
        <path d="M8 5v14l11-7z" fill="currentColor" />
      </svg>
      <svg class="icon-pause" viewBox="0 0 24 24" width="28" height="28" aria-hidden="true">
        <path d="M6 5h4v14H6zM14 5h4v14h-4z" fill="currentColor" />
      </svg>
    </button>

    <div class="player__timeline">
      <div class="player__seekrow">
        <input
          type="range"
          class="range range--seek"
          data-seek
          min="0"
          max="100"
          step="0.1"
          value="0"
          aria-label="Seek"
        />
      </div>
      <div class="player__times">
        <span data-current>0:00</span>
        <span data-duration>0:00</span>
      </div>
    </div>

    <div class="player__volume">
      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
        <path
          d="M3 10v4h4l5 5V5L7 10H3zm13.5 2a4.5 4.5 0 0 0-2.5-4.03v8.06A4.5 4.5 0 0 0 16.5 12z"
          fill="currentColor"
        />
      </svg>
      <input
        type="range"
        class="range range--volume"
        data-volume
        min="0"
        max="1"
        step="0.01"
        value="0.8"
        aria-label="Volume"
      />
    </div>
  </div>
</section>

<script>
  import { initPlayer } from '../scripts/player.js';
  const root = document.querySelector('[data-player]');
  if (root instanceof HTMLElement) initPlayer(root);
</script>

<style>
  .player {
    width: min(560px, 92vw);
    padding: clamp(1.6rem, 4vw, 2.6rem);
    border-radius: 24px;
    background: rgba(20, 16, 46, 0.42);
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow:
      0 24px 70px -20px rgba(0, 0, 0, 0.6),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(22px) saturate(1.2);
    -webkit-backdrop-filter: blur(22px) saturate(1.2);
    transition: box-shadow 0.5s ease, transform 0.5s ease;
  }

  /* Subtle lift + glow while playing. */
  .player.is-playing {
    box-shadow:
      0 28px 90px -18px rgba(0, 0, 0, 0.65),
      0 0 60px -12px rgba(147, 96, 205, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.16);
  }

  .player__meta {
    text-align: center;
    margin-bottom: clamp(1.4rem, 4vw, 2rem);
  }

  .player__eyebrow {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(226, 220, 255, 0.6);
    margin-bottom: 0.5rem;
  }

  .player__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 7vw, 3rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.01em;
    background: linear-gradient(120deg, #fff 0%, #dcd0ff 45%, #a7e8e0 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .player__controls {
    display: flex;
    align-items: center;
    gap: clamp(0.8rem, 3vw, 1.25rem);
  }

  /* Play / pause button */
  .player__play {
    flex: 0 0 auto;
    width: 60px;
    height: 60px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    color: #16112e;
    background: radial-gradient(circle at 35% 30%, #fef0f5, #e6c7ec 55%, #b79ce0 100%);
    box-shadow:
      0 8px 24px -6px rgba(183, 156, 224, 0.7),
      inset 0 1px 2px rgba(255, 255, 255, 0.8);
    transition: transform 0.2s ease, box-shadow 0.3s ease;
  }
  .player__play:hover {
    transform: scale(1.06);
    box-shadow: 0 10px 30px -6px rgba(183, 156, 224, 0.9);
  }
  .player__play:active {
    transform: scale(0.97);
  }
  .player__play:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
  }

  /* Toggle the play/pause glyphs based on state class on the player root. */
  .player__play .icon-pause { display: none; }
  .player.is-playing .player__play .icon-play { display: none; }
  .player.is-playing .player__play .icon-pause { display: block; }

  .player__timeline {
    flex: 1 1 auto;
    min-width: 0;
  }

  .player__times {
    display: flex;
    justify-content: space-between;
    font-variant-numeric: tabular-nums;
    font-size: 0.78rem;
    color: rgba(226, 220, 255, 0.7);
    margin-top: 0.4rem;
  }

  .player__volume {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(226, 220, 255, 0.75);
    width: clamp(64px, 22%, 110px);
  }

  /* ---- range inputs (seek + volume) --------------------------------------- */
  .range {
    --thumb: 15px;
    --fill: calc(var(--thumb) / 2);
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 6px;
    border-radius: 999px;
    background: linear-gradient(
      to right,
      #c9a9f0 0%,
      #a7e8e0 var(--fill),
      rgba(255, 255, 255, 0.16) var(--fill),
      rgba(255, 255, 255, 0.16) 100%
    );
    cursor: pointer;
    outline: none;
  }

  .range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 0 4px rgba(199, 169, 240, 0.35), 0 2px 6px rgba(0, 0, 0, 0.4);
    transition: box-shadow 0.2s ease, transform 0.15s ease;
  }
  .range::-webkit-slider-thumb:hover {
    transform: scale(1.15);
    box-shadow: 0 0 0 6px rgba(199, 169, 240, 0.45), 0 2px 8px rgba(0, 0, 0, 0.5);
  }
  .range::-moz-range-thumb {
    width: 15px;
    height: 15px;
    border: none;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 0 4px rgba(199, 169, 240, 0.35), 0 2px 6px rgba(0, 0, 0, 0.4);
  }
  .range::-moz-range-track {
    height: 6px;
    border-radius: 999px;
    background: transparent;
  }
  .range:focus-visible::-webkit-slider-thumb {
    box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 460px) {
    .player__volume { display: none; }
  }
</style>
